# Em produção com o mesmo host do front (nginx faz proxy para a API), use caminho relativo:
VITE_FRONTEND_API_URL=/clinicamedagil-service

# Docker Compose na VM: IP/porta onde o Spring escuta, visto de dentro do container `web`.
# Ajuste se o backend não estiver em 172.17.0.1:8080 (ex.: outro container na mesma rede).
# BACKEND_HOST=172.17.0.1
# BACKEND_PORT=8080

# Docker Compose (build/push na CI ou local): exporte também DOCKERHUB_USERNAME.
# Em produção via GitHub Actions, defina VITE_FRONTEND_API_URL em
# Settings → Secrets and variables → Actions → Variables (Repository variables).
