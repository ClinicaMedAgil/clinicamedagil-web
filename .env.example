# Em produção com proxy no mesmo host que o front, use caminho relativo:
VITE_FRONTEND_API_URL=/clinicamedagil-service

# Timeout do axios em ms (opcional; padrão 120000 = 2 min)
# VITE_API_TIMEOUT_MS=120000

# Onde o nginx do FRONT alcança a API (visto de dentro do container web):
# - Mesma rede Docker (ex.: serviço Spring "api"): BACKEND_HOST=api  BACKEND_PORT=8080
# - Duas VMs na Oracle: IP privado da VM da API, ex.: BACKEND_HOST=172.19.0.1
# BACKEND_HOST=172.19.0.1
# BACKEND_PORT=8080

# Docker Compose (opcional): IMAGE_TAG, HTTP_PORT.
